# ---- Kopiera till .env och fyll i innan `docker compose up` ----

# SQLite-databasens plats i containern (ligger på volymen emilia_data).
DATABASE_URL="file:/app/data/emilia.db"

# Hemlighet för att signera sessionscookies. Generera t.ex. med:
#   openssl rand -base64 32
AUTH_SECRET="byt-ut-mig-till-en-lang-slumpmassig-strang"

# Publik bas-URL (domänen NPM pekar mot). Används för säkra cookies/redirects.
AUTH_URL="https://emilia.dindoman.se"

# Admin (pappa) som seedas vid start.
ADMIN_EMAIL="pappa@example.com"
ADMIN_PASSWORD="byt-ut-mig"
ADMIN_NAME="Pappa Falk"

# Namnet på det EXTERNA Docker-nätverk som Nginx Proxy Manager ligger på.
# NPM proxar sedan mot http://emilia-web:3000 (containernamnet).
NPM_NETWORK="npm_network"
